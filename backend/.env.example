# =============================================================================
# Ollama
# =============================================================================

# Mode A: Ollama running on this MacBook.
OLLAMA_BASE_URL=http://localhost:11434

# Mode B: Ollama running on a Windows PC in the same LAN.
# OLLAMA_BASE_URL=http://<windows-lan-ip>:11434

OLLAMA_MODEL=gemma4
OLLAMA_TEMPERATURE=0.0
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=3
# Context window for Ollama. Set to 8192 for dialogue and extractor stages.
# Leave blank to use Ollama's default (4096).
OLLAMA_NUM_CTX=8192
# Extractor stages use per-stage num_predict budgets in factcheck/extractor/config.py
# (selection 512, disambiguation 768, decomposition 1024, fidelity/validation 256).
# Max simultaneous Ollama requests. Keep at 1 for consumer GPUs; set to 2 for high-VRAM machines.
OLLAMA_CONCURRENCY=1

# =============================================================================
# Search providers + DuckDuckGo rate-limit tuning
# =============================================================================

SEARCH_MAX_RESULTS=5
SEARCH_PROVIDER_ORDER=duckduckgo,tavily,serper
# DuckDuckGo retry/spacing (reduces rate-limit cascades during verifier loops).
DDG_MAX_RETRIES=3
DDG_RETRY_BASE_DELAY=1.0
DDG_RETRY_MAX_DELAY=8.0
DDG_MIN_REQUEST_INTERVAL=1.5
TAVILY_API_KEY=
SERPER_API_KEY=

# =============================================================================
# Dev / CORS
# =============================================================================

DEV_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080

# =============================================================================
# Persistence
# =============================================================================

SQLITE_PATH=factcheck_ai.db
DEBUG=false
